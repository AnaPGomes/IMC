<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Calculadora IMC</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="container">
    <h1>Calculadora de IMC</h1>
    <label>Peso (kg): <input id="peso" type="number" placeholder="ex: 70" /></label>
    <label>Altura (m): <input id="altura" type="number" placeholder="ex: 1.75" /></label>
    <button id="calcular">Calcular</button>
    <div id="resultado"></div>
  </div>
  <script src="app.js"></script>
</body>
</html>